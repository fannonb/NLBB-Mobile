{
  "name": "nlbb",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --max-workers 1",
    "start:safe": "expo start --clear --max-workers 1 --port 19000",
    "android": "expo run:android",
    "android:safe": "expo start --clear --max-workers 1 --port 19000 --android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "start:clear": "expo start --clear --max-workers 1",
    "build:apk": "eas build -p android --profile preview",
    "build:aab": "eas build -p android --profile production",
    "start:win": "expo start --clear --offline --max-workers 1 --port 8082",
    "android:win": "expo start --clear --offline --max-workers 1 --port 8082 --android",
    "web:win": "expo start --clear --offline --max-workers 1 --port 8082 --web",
    "start:win:tunnel": "expo start --clear --offline --max-workers 1 --port 8082 --tunnel",
    "web:pwa:dev": "npm --prefix web run dev",
    "web:pwa:build": "npm --prefix web run build",
    "web:pwa:preview": "npm --prefix web run preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.17.5",
    "babel-preset-expo": "~56.0.0",
    "expo": "^56.0.0",
    "expo-constants": "~56.0.18",
    "expo-font": "~56.0.7",
    "expo-image-picker": "~56.0.18",
    "expo-linear-gradient": "~56.0.4",
    "expo-location": "~56.0.18",
    "expo-notifications": "~56.0.18",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-updates": "~56.0.19",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.72.1",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-maps": "1.27.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.0",
    "react-native-webview": "^14.0.1",
    "react-native-worklets": "0.8.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.0",
    "@types/react": "~19.2.14",
    "typescript": "~6.0.3"
  },
  "private": true
}
