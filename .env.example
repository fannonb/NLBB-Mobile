# Expo mobile app
# For Android/iOS simulators you can often use localhost.
# For a physical device, use your machine LAN IP or an HTTPS tunnel.
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000/api
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_ENABLE_DEMO_MODE=false
EXPO_PUBLIC_ALLOW_SEEDED_IDENTITIES=false

# Google Maps SDK key (Android + iOS) for the customer Map screen.
# Create one at https://console.cloud.google.com/google/maps-apis/credentials
# Without this, the map renders blank/grey tiles.
GOOGLE_MAPS_API_KEY=
